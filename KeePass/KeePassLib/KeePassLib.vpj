        SaveOption="SaveAll"
        RunFromDir="%rw"
        ClearProcessBuffer="1">
        <Exec CmdLine="vstudiocompile"/>
      </Target>
      <Target
        Name="DebugVisualStudio"
        MenuCaption="Debug - Visual Studio"
        CaptureOutputWith="ProcessBuffer"
        SaveOption="SaveAll"
        RunFromDir="%rw"
        ClearProcessBuffer="1">
        <Exec CmdLine='devenv "%w"'/>
      </Target>
      <Target
        Name="Execute"
        MenuCaption="E&amp;xecute"
        SaveOption="SaveAll"
        CaptureOutputWith="ProcessBuffer"
        RunFromDir="%rw"
        ClearProcessBuffer="1">
        <Exec CmdLine='"%o"'/>
      </Target>
    </Menu>
  </Config>
